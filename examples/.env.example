# OpenDuck environment variables reference
# Copy to .env and adjust as needed.

# --- Authentication ---
OPENDUCK_TOKEN=my-secret-token

# --- Postgres metadata ---
DATABASE_URL=postgres://openduck:openduck@localhost:5433/openduck_meta

# --- Worker ---
OPENDUCK_WORKER_LISTEN=127.0.0.1:9898
# Optional: path to a DuckDB file (default: in-memory)
# OPENDUCK_WORKER_DB=/path/to/database.duckdb

# --- Gateway ---
OPENDUCK_WORKER_ADDRS=http://127.0.0.1:9898
OPENDUCK_MAX_IN_FLIGHT=64

# --- C++ Extension (client-side) ---
OPENDUCK_ENDPOINT=http://127.0.0.1:7878

# --- DuckLake (optional) ---
# OPENDUCK_DUCKLAKE_METADATA=postgres://user:pass@localhost:5433/ducklake_meta
# OPENDUCK_DUCKLAKE_DATA=s3://openduck-data/lake/
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# AWS_ENDPOINT_URL=http://localhost:9000

# --- Observability (optional) ---
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
