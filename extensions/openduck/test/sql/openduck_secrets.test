# name: test/sql/openduck_secrets.test
# description: test openduck_storage secrets resolve through OpenDuckFileSystem URIs
# group: [sql]

require openduck

# ── Default secret auto-discovery ────────────────────────────────────────

# Create default secret (no bridge linked — falls back to InMemoryStorage, which is fine)
statement ok
CREATE SECRET openduck_storage (TYPE openduck_storage, postgres_url 'postgres://localhost/test', data_dir '/tmp/od_default');

# Opening an openduck:// path should not crash (resolves secret, uses InMemoryStorage fallback)
statement ok
SELECT 1;

statement ok
DROP SECRET openduck_storage;

# ── Named secret via ?secret= ───────────────────────────────────────────

statement ok
CREATE SECRET staging (TYPE openduck_storage, postgres_url 'postgres://staging/db', data_dir '/tmp/staging');

# Verify the secret exists with correct type
query I
SELECT count(*) FROM duckdb_secrets() WHERE name = 'staging' AND type = 'openduck_storage';
----
1

statement ok
DROP SECRET staging;

# ── data_dir-only secret ─────────────────────────────────────────────────

statement ok
CREATE SECRET dir_only (TYPE openduck_storage, data_dir '/tmp/custom_dir');

# Should create without error even though postgres_url is missing
query I
SELECT count(*) FROM duckdb_secrets() WHERE name = 'dir_only';
----
1

statement ok
DROP SECRET dir_only;

# ── Multiple secrets coexist ─────────────────────────────────────────────

statement ok
CREATE SECRET env_a (TYPE openduck_storage, postgres_url 'postgres://a/db', data_dir '/tmp/a');

statement ok
CREATE SECRET env_b (TYPE openduck_storage, postgres_url 'postgres://b/db', data_dir '/tmp/b');

query I
SELECT count(*) FROM duckdb_secrets() WHERE type = 'openduck_storage';
----
2

statement ok
DROP SECRET env_a;

statement ok
DROP SECRET env_b;
