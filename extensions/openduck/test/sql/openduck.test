# name: test/sql/openduck.test
# description: test openduck extension loads and registers functions
# group: [sql]

# Require statement will ensure this test is run with this extension loaded
require openduck

# Verify both table functions are registered
query I
SELECT count(*) FROM duckdb_functions() WHERE function_name = 'openduck_remote';
----
1

query I
SELECT count(*) FROM duckdb_functions() WHERE function_name = 'openduck_query';
----
1

# openduck_query with a missing alias should error cleanly (no gRPC call)
statement error
SELECT * FROM openduck_query('nonexistent', 'SELECT 1');
----
No ATTACH config for alias

# ── Secret type: openduck_storage ────────────────────────────────────────

# Create a default-named secret
statement ok
CREATE SECRET openduck_storage (TYPE openduck_storage, postgres_url 'postgres://fake:5432/test', data_dir '/tmp/od_test');

# Create a named secret
statement ok
CREATE SECRET my_prod (TYPE openduck_storage, postgres_url 'postgres://prod:5432/db', data_dir '/mnt/prod');

# Verify secrets are visible and postgres_url is redacted
query I
SELECT count(*) FROM duckdb_secrets() WHERE type = 'openduck_storage';
----
2

query I
SELECT secret_string LIKE '%postgres_url=redacted%' FROM duckdb_secrets() WHERE type = 'openduck_storage' AND name = 'my_prod';
----
true

# Clean up
statement ok
DROP SECRET openduck_storage;

statement ok
DROP SECRET my_prod;
