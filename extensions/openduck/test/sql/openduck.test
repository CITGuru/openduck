# name: test/sql/openduck.test
# description: test openduck extension loads and registers functions
# group: [sql]

# Require statement will ensure this test is run with this extension loaded
require openduck

# Verify openduck_remote function is registered (will fail at connect but that's OK)
statement error
SELECT * FROM openduck_remote('http://localhost:1', 'tok', 'SELECT 1');
----

# Verify openduck_query function is registered (will fail with no config but that's OK)
statement error
SELECT * FROM openduck_query('nonexistent', 'SELECT 1');
----

# ── Secret type: openduck_storage ────────────────────────────────────────

# Create a default-named secret
statement ok
CREATE SECRET openduck_storage (TYPE openduck_storage, postgres_url 'postgres://fake:5432/test', data_dir '/tmp/od_test');

# Create a named secret
statement ok
CREATE SECRET my_prod (TYPE openduck_storage, postgres_url 'postgres://prod:5432/db', data_dir '/mnt/prod');

# Verify secrets are visible and postgres_url is redacted
query III
SELECT name, type, trim(split_part(value, ';', 1)) FROM duckdb_secrets() WHERE type = 'openduck_storage' ORDER BY name;
----
my_prod	openduck_storage	postgres_url=********
openduck_storage	openduck_storage	postgres_url=********

# Clean up
statement ok
DROP SECRET openduck_storage;

statement ok
DROP SECRET my_prod;
